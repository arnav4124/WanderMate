@startuml adr001_event_flow
skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam sequenceArrowThickness 2
skinparam sequenceLifeLineBorderColor #333333
skinparam sequenceParticipantBackgroundColor #DBEAFE
skinparam sequenceParticipantBorderColor #3B82F6
skinparam sequenceDividerBackgroundColor #F3F4F6

title ADR-001 — Collaborative Edit Sequence (MongoDB Primary + Firebase Sync Channel)

participant "User A\n(Mobile Client)" as A #DBEAFE
participant "API Gateway\n(Express)" as GW #D1FAE5
participant "TripController" as TC #D1FAE5
participant "MongoDB\n(Mongoose)" as DB #FEF3C7
participant "TripObserver\n(EventEmitter)" as OBS #FFF3E0
participant "Firebase\nRTDB" as FB #FFF3E0
participant "User B\n(Mobile Client)" as B #DBEAFE

A -> GW : PUT /api/trips/:id/days/0/stops/:stopId\n+ JWT Bearer Token
activate GW

GW -> GW : authenticate() — verify JWT
GW -> TC : updateStop(req, res)
activate TC

TC -> DB : Trip.findById(id)
activate DB
DB --> TC : trip document
deactivate DB

TC -> TC : Authorization check:\ntrip.owner === req.user.uid ||\ntrip.collaborators.includes(req.user.uid)

TC -> DB : Object.assign(stop, updates)\nawait trip.save()
activate DB
DB --> TC : saved trip
deactivate DB

== MongoDB updated (source of truth) ==

TC -> OBS : tripEvents.emit(\n'TRIP_UPDATED', trip._id, req.user.uid)
activate OBS

TC --> GW : res.json(trip)
deactivate TC
GW --> A : 200 OK + updated trip JSON
deactivate GW

OBS -> FB : firebaseDB.ref('trips/' + tripId).set(sanitizedTrip)\n// includes updatedAt + lastEditedBy
deactivate OBS

== Firebase trip snapshot propagates ==

FB -> B : onValue callback fires\n(tripStore.subscribeTripUpdates)
activate B
B -> B : Compare updatedAt (LWW)\nApply newer snapshot to local state
deactivate B

note over FB
  MongoDB remains the
  single source of truth.
  Firebase is used for
  real-time propagation
  of server-produced
  trip snapshots.
end note

@enduml
